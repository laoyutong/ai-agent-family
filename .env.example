# DeepSeek API（与 OpenAI SDK 兼容，密钥在控制台创建）
# 复制为仓库根目录 `.env` 后填写，勿提交 `.env`
DEEPSEEK_API_KEY=

# 以下为 chatbot-memory 默认值（均可省略）；需要时再改
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 会话历史：超过上限从最早一轮丢弃；MAX_CHARS=0 表示不按字符限制
# CHAT_HISTORY_MAX_PAIRS=30
# CHAT_HISTORY_MAX_CHARS=0

# 裁切丢轮时折叠进「长期要点」+「会话前期摘要」（默认开启；false/0/off 关闭）
# CHAT_HISTORY_SUMMARIZE=true

# 增量摘要：总轮数为 N 的整数倍时融合队首 N 轮（默认 5；设为 0 关闭）
# CHAT_INCREMENTAL_SUMMARY_EVERY_N_PAIRS=5

# 困惑度/信息熵过滤：主对话前多一次非流式压缩上下文（默认开启；false/0/off 关闭）
# CHAT_CONTEXT_ENTROPY_PPL_FILTER=true
# 历史+当前用户总字符 ≥ 此值才触发；0 表示总是触发
# CHAT_CONTEXT_ENTROPY_PPL_MIN_CHARS=1800
# CHAT_CONTEXT_ENTROPY_PPL_MODEL=
# CHAT_CONTEXT_ENTROPY_PPL_MAX_TOKENS=8192
