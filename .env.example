# DeepSeek API（与 OpenAI SDK 兼容，密钥在控制台创建）
# 复制为仓库根目录 `.env` 后填写，勿提交 `.env`
DEEPSEEK_API_KEY=

# 以下为 chatbot-memory 默认值（均可省略）；需要时再改
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 会话历史：超过上限从最早一轮丢弃；MAX_CHARS=0 表示不按字符限制
# CHAT_HISTORY_MAX_PAIRS=30
# CHAT_HISTORY_MAX_CHARS=0

# 裁切丢轮时折叠进「长期要点」+「会话前期摘要」（默认开启；false/0/off 关闭）
# CHAT_HISTORY_SUMMARIZE=true

# 增量摘要：总轮数为 N 的整数倍时融合队首 N 轮（默认 5；设为 0 关闭）
# CHAT_INCREMENTAL_SUMMARY_EVERY_N_PAIRS=5

# 困惑度/信息熵过滤：主对话前多一次非流式压缩上下文（默认开启；false/0/off 关闭）
# CHAT_CONTEXT_ENTROPY_PPL_FILTER=true
# 历史+当前用户总字符 ≥ 此值才触发；0 表示总是触发
# CHAT_CONTEXT_ENTROPY_PPL_MIN_CHARS=1800
# CHAT_CONTEXT_ENTROPY_PPL_MODEL=
# CHAT_CONTEXT_ENTROPY_PPL_MAX_TOKENS=8192

# MCP（可选）：JSON 数组；字符串里可写 ${VAR}，启动时用同名环境变量替换（便于路径等单独配置）。
# filesystem 服务只能访问「该目录及其子目录」；要读项目下的 code/，请设为 code 的父目录（例如仓库根或你的工程根），不要用 /tmp。
# MCP_FILESYSTEM_ROOT=/path/to/parent-of-code
# MCP_SERVERS=[{"id":"fs","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","${MCP_FILESYSTEM_ROOT}"]}]
# 避免 DeepSeek 返回 413 Request Entity Too Large：限制工具数量、单工具 schema、工具返回与整段对话 JSON 体积
# CHAT_MCP_MAX_TOOLS=48
# CHAT_MCP_TOOL_PARAM_MAX_BYTES=6144
# CHAT_MCP_TOOLS_JSON_MAX_BYTES=450000
# CHAT_MCP_TOOL_RESULT_MAX_CHARS=65536
# CHAT_MCP_CONTEXT_MAX_JSON_BYTES=1200000

# MCP 代码沙盒（streamChatWithMcpTools）：用户代码总执行时长上限（毫秒）与单次执行内 MCP 调用次数上限
# CHAT_MCP_CODE_MAX_MS=30000
# CHAT_MCP_CODE_MAX_CALLS=32

# 是否在助手回复开头回显本次沙盒执行的 MCP 代码块（默认 false，不向用户披露代码；true 仅作调试）
# CHAT_MCP_ECHO_CODE_IN_CHAT=false

# chatbot-memory：多会话本地持久化文件路径（默认 ~/.chatbot-memory/sessions.json）
# CHAT_SESSION_STORE_PATH=
