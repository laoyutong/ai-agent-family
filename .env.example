# DeepSeek API（与 OpenAI SDK 兼容，密钥在控制台创建）
# 复制为仓库根目录 `.env` 后填写，勿提交 `.env`
DEEPSEEK_API_KEY=

# 可选覆盖（默认见 apps/chatbot-memory）
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 会话历史精简：超过上限时从最早一轮开始丢弃；0 表示不按该项限制
# CHAT_HISTORY_MAX_PAIRS=30
# CHAT_HISTORY_MAX_CHARS=0
# 为 true/1 时，丢弃部分会先经一次非流式调用折叠进记忆分层：「长期要点」+「会话前期摘要」
# CHAT_HISTORY_SUMMARIZE=false
