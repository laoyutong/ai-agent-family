# DeepSeek API（与 OpenAI SDK 兼容，密钥在控制台创建）
# 复制为仓库根目录 `.env` 后填写，勿提交 `.env`
DEEPSEEK_API_KEY=

# 以下为 chatbot-memory 默认值（均可省略）；需要时再改
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 会话历史：超过上限从最早一轮丢弃（仅按轮数）
# CHAT_HISTORY_MAX_PAIRS=30

# 裁切丢轮时折叠进「长期要点」+「会话前期摘要」（默认开启；false/0/off 关闭）
# CHAT_HISTORY_SUMMARIZE=true

# 增量摘要：总轮数为 N 的整数倍时融合队首 N 轮（默认 5；设为 0 关闭）
# CHAT_INCREMENTAL_SUMMARY_EVERY_N_PAIRS=5

# 困惑度/信息熵过滤：主对话前多一次非流式压缩上下文（默认开启；false/0/off 关闭）
# CHAT_CONTEXT_ENTROPY_PPL_FILTER=true
# 历史+当前用户总字符 ≥ 此值才触发；0 表示总是触发
# CHAT_CONTEXT_ENTROPY_PPL_MIN_CHARS=1800
# CHAT_CONTEXT_ENTROPY_PPL_MODEL=
# CHAT_CONTEXT_ENTROPY_PPL_MAX_TOKENS=8192

# MCP（可选）：JSON 数组；字符串里可写 ${VAR}，启动时用同名环境变量替换（便于路径等单独配置）。
# filesystem 服务只能访问「该目录及其子目录」；要读项目下的 code/，请设为 code 的父目录（例如仓库根或你的工程根），不要用 /tmp。
# MCP_FILESYSTEM_ROOT=/path/to/parent-of-code
# MCP_SERVERS=[{"id":"fs","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","${MCP_FILESYSTEM_ROOT}"]}]
# 每轮是否先轻量路由：仅当判定需要 MCP 时才走代码沙盒（默认 true）；false 则只要 listTools 非空即走沙盒（旧行为）
# CHAT_MCP_TURN_ROUTER=true

# MCP 路由前是否启用关键词/正则预判（默认 true）：明显寒暄可跳过 listTools 与路由 LLM；明显工具意图直接走沙盒；false 则每轮仍走原路由 LLM（若 TURN_ROUTER 开启）
# CHAT_MCP_ROUTER_HEURISTIC=true

# MCP 多步 Plan-Execute：先非流式输出 json 步骤，再按步生成代码+沙盒；解析失败或工具数不足则回退单段代码路径。详见 apps/chatbot-memory/docs/ARCHITECTURE.md
# CHAT_MCP_PLAN_EXECUTE=true
# listTools 合并条数 ≥ 此值才走规划（默认 2；仅 1 个工具时常跳过以省一次规划调用）
# CHAT_MCP_PLAN_MIN_TOOLS=2
# 规划里最多保留几步（默认 8）
# CHAT_MCP_PLAN_MAX_STEPS=8
# 每一步内「代码生成/沙盒失败」最大重试轮数（默认 6；单段整任务轮次上限见源码 MAX_MCP_CODE_ROUNDS）
# CHAT_MCP_PLAN_STEP_CODE_ROUNDS=6

# MCP 代码沙盒（streamChatWithMcpTools）：用户代码总执行时长上限（毫秒）与单次执行内 MCP 调用次数上限
# CHAT_MCP_CODE_MAX_MS=30000
# CHAT_MCP_CODE_MAX_CALLS=32

# 默认 false：在独立子进程中跑 node:vm，并剥离子进程环境中的 API 密钥 / MCP_SERVERS 等（见 apps/chatbot-memory/docs/ARCHITECTURE.md）
# true：同进程 vm，仅建议本机调试（vm 逃逸将影响整个服务进程）
# CHAT_MCP_SANDBOX_IN_PROCESS=false
# 沙盒子进程池：复用 fork，降低 Plan-Execute 多步/多轮代码执行开销。默认 4；设为 0 则每次执行新建子进程（旧行为）
# CHAT_MCP_SANDBOX_POOL_SIZE=4

# 是否在助手回复开头回显本次沙盒执行的 MCP 代码块（默认 false，不向用户披露代码；true 仅作调试）
# CHAT_MCP_ECHO_CODE_IN_CHAT=false

# chatbot-memory：会话存储（默认 ~/.chatbot-memory/sessions/ 目录；路径以 .json 结尾则为单文件模式）
# CHAT_SESSION_STORE_PATH=

# 用户级长期事实（跨所有会话注入 system；记忆折叠后可自动合并本会话新增要点）
# CHAT_USER_FACTS_PATH=
# CHAT_USER_FACTS_MAX_LINES=200
# CHAT_USER_FACTS_PROMOTE_LLM=false
# CHAT_USER_FACTS_PROMOTE_MODEL=
