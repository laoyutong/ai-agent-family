{
  "name": "aura-code",
  "version": "0.0.0",
  "private": true,
  "description": "光环代码：终端 AI 编程助手，受 Claude Code 架构启发，基于 DeepSeek API 的工具调用代理",
  "type": "module",
  "bin": {
    "aura-code": "./dist/main.js"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "link:global": "pnpm run build && pnpm link --global"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "glob": "^11.0.1",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "string-width": "^8.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
